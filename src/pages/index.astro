---
// Homepage layout

import Layout from "../layouts/Layout.astro";
import { getEntry } from "astro:content";

const home = await getEntry("page", "home");
const settings = await getEntry("page", "settings");
const { Content } = await home.render();
---

<Layout title={home.data.title} description={home.data.description}>
    <main class="site">
        <div class="hero">
            <h1>
                Shiatsu massage therapy in Montreal / Tioh'tia:ke / Mooniyang
            </h1>
            <p>
                Alex Nawotka (they/them), certified massage therapist
            </p>
        </div>

        <div class="booking">
            <h2>Book with me</h2>
            <div class="card">
                <h3>At your home / Mobile Shiatsu massage</h3>
                <p>
                    60-minute massage, $60-100 (sliding scale) + transport fees <br
                    />
                    At your location, Greater Montreal Area
                </p>
                <a
                    class="button"
                    href="https://cal.com/liminalcareshiatsu/home"
                    target="_blank">Book an at-home massage</a
                >
                <p>You can also book via email at <strong>alex@liminalcareshiatsu.com</strong>.</p>
            </div>
            
            <div class="card">
                <h3>Shiatsu massage in the Plateau (friends only!)</h3>
                <p>
                    60-minute massage, $60-100 (sliding scale) <br
                    />
                    Coordinates of my top secret lab will be shared via email after confirmation <br/>
                </p>
                <a
                    class="button outline"
                    href="https://cal.com/liminalcareshiatsu/plateau"
                    target="_blank">Book in the Plateau (friends only!)</a
                >
                <p>You can also book via email at <strong>alex@liminalcareshiatsu.com</strong>.</p>
            </div>
            <p>Let me know in advance if you need an insurance receipt!</p>
        </div>

        <h2>What is shiatsu?</h2>
        <p>
            Shiatsu is a Japanese therapeutic massage technique using deep,
            targeted pressure on specific points to promote balance,
            circulation, and restore health. It is received fully clothed on a
            futon on the floor.
        </p>
        <p>
            Shiatsu can benefit a variety of physical, emotional, and
            psychological conditions including:
            <ul>
                <li>
                    stress, muscle tension, neck and shoulder tension,
                    migraines, back pain, sciatic nerve, carpal tunnel
                </li>
                <li>anxiety, insomnia, nervous system disregulation</li>
                <li>digestive problems, diarrhea, constipation</li>
                <li>breathing problems, sinusitis, cold hands and feet</li>
            </ul>
        </p>
        <figure>
            <iframe
                width="560"
                height="315"
                src="https://www.youtube-nocookie.com/embed/2sHZM9L40pY?si=y1t57-19i-l-P8Ba"
                title="YouTube video player"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                referrerpolicy="strict-origin-when-cross-origin"
                allowfullscreen></iframe>
            <figcaption>
                What is Shiatsu Massage? | Massage Therapy School Training at
                École Setsuko
            </figcaption>
        </figure>

        <p>
            My training is in the Zen Shiatsu lineage, developed by Shizuto
            Masunaga in the 1960-70s. This approach integrates healing concepts
            from Traditional Chinese Medicine (TCM) alongside Western approaches
            to physiology, pathology, and holistic wellbeing.
        </p>

        <p>
            Feel free to ask me questions about Shiatsu, even very basic ones!
            I’d love to share what I know, and I’m very curious what kind of
            info & how much detail folks would like to know before booking their
            first shiatsu massage.
        </p>

        <h2>About me</h2>
        <p>
            I’m Alex Nawotka (they/them), a queer massage therapist living on
            unceded Kanien’kehá:ka land, in Tioh’tià:ke / Mooniyang / Montréal,
            QC. I completed the Shiatsu diploma program at École Setsuko from
            Jan 2024-2026.
        </p>
        <p>You can contact me at alex@liminalcareshiatsu.com.</p>

        <div class="content">
            <Content />
        </div>

        <h2>Community resources</h2>
        <p>
            Here are a few local initiatives I'm aware of that may be helpful
            for finding complementary care ✧.*
            <ul>
                <li>
                    <a
                        href="https://affordabletherapynetwork.com/"
                        target="_blank"
                    >
                        Affordable Therapy Network
                    </a>, a directory of therapists offering low cost & sliding
                    scale counselling across Canada
                </li>
                <li>
                    <a
                        href="https://www.communityhealingdays.ca/"
                        target="_blank">Community Healing Days</a
                    >, low cost sliding scale healing project offering
                    traditional therapies to low income and marginalized folks
                    in Tiohtià:ke (Montreal) who are underserved by the public
                    healthcare system
                </li>
                <li>
                    <a
                        href="https://www.blackhealingcentre.com/"
                        target="_blank">Black Healing Centre</a
                    >, free and subsidized therapeutic services and programming
                    that aims to empower people of African and Caribbean descent
                    in Tiohtià:ke (Montreal)
                </li>
                <li>
                    <a href="https://transpatientunion.org/en/" target="_blank"
                        >Trans Patient Union</a
                    >, coalition by and for trans & nonbinary patients receiving
                    or trying to receive care in Tiohtià:ke (Montreal)
                </li>
                <li>
                    <a href="https://montrealdaoist.com/" target="_blank"
                        >Daoist Arts Community Centre</a
                    >, a place for the study and practice of Daoist Arts:
                    Acupuncture, Chinese Medicine, Qi Gong,Tai Ji Quan and
                    Somatic healing arts
                </li>
            </ul>

            <h2>Sign up for my newsletter</h2>
            <iframe
                src="https://liminalcareshiatsu.substack.com/embed"
                width="480"
                height="320"
                style="border:1px solid #EEE; background:#BCD7F1;"
                class="card"
                frameborder="0"
                scrolling="no"></iframe>
        </p>
    </main>

    <style lang="scss">
        @use "../styles/base/vars" as *;

        .hero {
            margin-bottom: 2.5rem;
        }

        .card {
            background-color: var(--color-light-secondary);
            padding: 0.8rem 0.5rem;
            border-radius: var(--border-radius);
            margin-bottom: 1.5rem;
        }

        iframe.card {
            padding: 0;
            margin-top: 1.5rem;
            background: var(--color-light-secondary) !important;
            html,
            & > * {
                background: var(--color-light-secondary) !important;
                :root {
                    --color_bg_color: #bcd7f1;
                }
            }
        }

        .booking {
            margin-bottom: 3rem;
        }

        figure {
            display: flex;
            flex-direction: column;
            align-items: center;
        }
    </style>
</Layout>
